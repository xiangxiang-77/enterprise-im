MYSQL_DATABASE=enterprise_im
MYSQL_USER=enterprise_im
MYSQL_PASSWORD=enterprise_im_dev
MYSQL_ROOT_PASSWORD=enterprise_im_root
MYSQL_PORT=3307

# Optional override: use Derby/MySQL/PostgreSQL-compatible JDBC settings.
# SPRING_PROFILES_ACTIVE=derby
# DB_URL=jdbc:derby:./data/enterprise-im-derby;create=true
# DB_USERNAME=enterprise_im
# DB_PASSWORD=enterprise_im_dev
# DB_DRIVER=org.apache.derby.jdbc.EmbeddedDriver

HTTP_PORT=8080
TCP_PORT=9000
DEMO_TOKEN_PREFIX=demo-token-
ADMIN_PASSWORD=admin123
JWT_ISSUER=enterprise-im
JWT_SECRET=change-me-enterprise-im-jwt-secret
ACCESS_TOKEN_TTL_SECONDS=86400

REDIS_PORT=6379
MINIO_API_PORT=9001
MINIO_CONSOLE_PORT=9002
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=enterprise-im

TURN_PORT=3478
TURN_REALM=enterprise-im.local
TURN_USERNAME=enterprise-im
TURN_PASSWORD=enterprise-im-secret

SIP_PORT=5060
SIP_DOMAIN=enterprise-im.local
SIP_REGISTRAR=sip:127.0.0.1:5060
SIP_ANDROID_REGISTRAR=sip:10.0.2.2:5060
SIP_REALM=enterprise-im.local
SIP_PASSWORD=enterprise-im-sip-secret
ASTERISK_RTP_START=10000
ASTERISK_RTP_END=10020

# Optional native PJSIP media engine. Leave blank to use simulated gateway mode.
PJSUA_BIN=/opt/pjsip/bin/pjsua
PJSIP_SIP_DOMAIN=enterprise-im.local
PJSIP_REGISTRAR=sip:asterisk:5060
PJSIP_REALM=enterprise-im.local
PJSIP_USERNAME=u_gateway
PJSIP_PASSWORD=enterprise-im-sip-secret
PJSUA_EXTRA_ARGS=
PJSIP_CREATE_CMD=
PJSIP_ANSWER_CMD=
PJSIP_HANGUP_CMD=

PJSIP_GATEWAY_PORT=7070
PJSIP_SIGNAL_URL=http://pjsip-gateway:7070

# Push notification provider: mock / fcm / apns
PUSH_PROVIDER=mock

# Firebase Cloud Messaging (required when PUSH_PROVIDER=fcm)
# FCM_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}
# FCM_PROJECT_ID=your-project-id

# Apple Push Notification service (required when PUSH_PROVIDER=apns)
# APNS_TEAM_ID=ABCDEF1234
# APNS_KEY_ID=ABCDEF1234
# APNS_PRIVATE_KEY_PATH=/path/to/AuthKey_ABCDEF1234.p8
# APNS_TOPIC=com.example.app
# APNS_PRODUCTION=true

# Baidu OCR (for image text recognition)
# BAIDU_OCR_API_KEY=your-baidu-api-key
# BAIDU_OCR_SECRET_KEY=your-baidu-secret-key

# OnlyOffice document preview
# ONLYOFFICE_API_URL=https://your-onlyoffice-server.example.com
# ONLYOFFICE_SECRET_KEY=your-onlyoffice-secret-key
